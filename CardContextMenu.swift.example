// CardContextMenu 示例代码 for ReviewView
// 实现卡片的长按菜单

import SwiftUI
import AnkiKit

// ===== 第1步：在 ReviewSession 中添加新方法 =====

// 在 ReviewSession.swift 的 class 中添加：

@Observable @MainActor
final class ReviewSession {
    // ... 现有代码 ...
    
    // ===== 卡片操作方法 =====
    
    func suspend() {
        guard let queued = currentQueuedCard else { return }
        
        do {
            print(\"[CardOps] Suspending card #\\(queued.card.id)\")
            try deckClient.suspend(queued.card.id)
            
            // 卡片已暂停，移动到下一张
            advanceToNextCard()
            
            // 更新统计
            sessionStats.suspended += 1
        } catch {
            print(\"[CardOps] Suspend failed: \\(error)\")
            // TODO: 显示错误提示给用户
        }
    }
    
    func bury() {
        guard let queued = currentQueuedCard else { return }
        
        do {
            print(\"[CardOps] Burying card #\\(queued.card.id)\")
            try deckClient.bury(queued.card.id)
            
            // 卡片已搁置，移动到下一张
            advanceToNextCard()
            
            // 更新统计
            sessionStats.buried += 1
        } catch {
            print(\"[CardOps] Bury failed: \\(error)\")
        }
    }
    
    func undo() {
        do {
            print(\"[CardOps] Undo last action\")
            try deckClient.undo(currentQueuedCard?.card.id ?? 0)
            
            // 撤销会影响整个队列，重新加载
            start()
        } catch {
            print(\"[CardOps] Undo failed: \\(error)\")
        }
    }
    
    func flag(color: Int) {
        guard let queued = currentQueuedCard else { return }
        
        do {
            print(\"[CardOps] Flagging card #\\(queued.card.id) with color \\(color)\")
            // TODO: 实现 cardClient.flag(cardId, color)
            // try deckClient.flag(queued.card.id, color)
        } catch {
            print(\"[CardOps] Flag failed: \\(error)\")
        }
    }
    
    func editCurrentNote() {
        guard let queued = currentQueuedCard else { return }
        shouldShowNoteEditor = true
        editingNote = NoteRecord(id: queued.note.id)  // 简化示例
    }
}

// ===== 第2步：创建卡片菜单 View =====

// 新文件: CardContextMenuView.swift

struct CardContextMenuView: View {
    @ObservedReferenceable var session: ReviewSession
    
    var body: some View {
        VStack(spacing: 0) {
            // 标题
            HStack {
                Text(\"Card Options\")
                    .font(.caption.weight(.semibold))
                    .foregroundStyle(.secondary)
                
                Spacer()
                
                Button {
                    session.showCardMenu = false
                } label: {
                    Image(systemName: \"xmark.circle.fill\")
                        .foregroundStyle(.secondary)
                }
            }
            .padding(.horizontal, 12)
            .padding(.vertical, 8)
            
            Divider()
            
            // 菜单项
            VStack(spacing: 0) {
                // Suspend
                MenuItemButton(
                    icon: \"pause.circle\",
                    title: \"Suspend\",
                    subtitle: \"Hide until tomorrow\",
                    color: .orange,
                    action: {
                        session.suspend()
                        session.showCardMenu = false
                    }
                )
                
                Divider()
                    .padding(.horizontal, 12)
                
                // Bury
                MenuItemButton(
                    icon: \"moon.circle\",
                    title: \"Bury\",
                    subtitle: \"Hide until next interval\",
                    color: .indigo,
                    action: {
                        session.bury()
                        session.showCardMenu = false
                    }
                )
                
                Divider()
                    .padding(.horizontal, 12)
                
                // Flag
                HStack(spacing: 12) {
                    Image(systemName: \"flag.circle\")
                        .font(.title3)
                        .foregroundStyle(.primary)
                    
                    VStack(alignment: .leading, spacing: 2) {
                        Text(\"Flag\")
                            .font(.body.weight(.medium))
                        Text(\"Mark for review\")
                            .font(.caption)
                            .foregroundStyle(.secondary)
                    }
                    
                    Spacer()
                    
                    // 颜色选择器
                    HStack(spacing: 4) {
                        ForEach(0..<7, id: \\.self) { color in
                            Button {
                                session.flag(color: color)
                                session.showCardMenu = false
                            } label: {
                                Circle()
                                    .fill(flagColor(color))
                                    .frame(width: 20, height: 20)
                            }
                        }
                    }
                }
                .padding(.horizontal, 12)
                .padding(.vertical, 10)
                
                Divider()
                    .padding(.horizontal, 12)
                
                // Edit Note
                MenuItemButton(
                    icon: \"pencil.circle\",
                    title: \"Edit Note\",
                    subtitle: \"Modify card content\",
                    color: .blue,
                    action: {
                        session.editCurrentNote()
                        session.showCardMenu = false
                    }
                )
                
                Divider()
                    .padding(.horizontal, 12)
                
                // Undo (always available, even if no undoable action)
                MenuItemButton(
                    icon: \"arrow.uturn.backward.circle\",
                    title: \"Undo\",
                    subtitle: \"Revert last action\",
                    color: .gray,
                    action: {
                        session.undo()
                        session.showCardMenu = false
                    }
                )
                
                Divider()
                    .padding(.horizontal, 12)
                
                // Card Info
                MenuItemButton(
                    icon: \"info.circle\",
                    title: \"Card Info\",
                    subtitle: \"View card details\",
                    color: .green,
                    action: {
                        session.showCardInfo = true
                        session.showCardMenu = false
                    }
                )
            }
        }
        .background(.ultraThinMaterial)
        .cornerRadius(12)
        .shadow(radius: 8)
        .padding(16)
    }
    
    private func flagColor(_ index: Int) -> Color {
        switch index {
        case 0: return .clear
        case 1: return .red
        case 2: return .orange
        case 3: return .green
        case 4: return .blue
        case 5: return .pink
        case 6: return .cyan
        default: return .gray
        }
    }
}

// 菜单项组件
private struct MenuItemButton: View {
    let icon: String
    let title: String
    let subtitle: String
    let color: Color
    let action: () -> Void
    
    var body: some View {
        Button(action: action) {
            HStack(spacing: 12) {
                Image(systemName: icon)
                    .font(.title3)
                    .foregroundStyle(color)
                    .frame(width: 24)
                
                VStack(alignment: .leading, spacing: 2) {
                    Text(title)
                        .font(.body.weight(.medium))
                        .foregroundStyle(.primary)
                    Text(subtitle)
                        .font(.caption)
                        .foregroundStyle(.secondary)
                }
                
                Spacer()
            }
            .padding(.horizontal, 12)
            .padding(.vertical, 10)
            .contentShape(Rectangle())
        }
    }
}

// ===== 第3步：在 ReviewView 中集成菜单 =====

// 修改 ReviewView.swift

struct ReviewView: View {
    let deckId: Int64
    let onDismiss: () -> Void

    @State private var session: ReviewSession
    @State private var showCardMenu = false
    @State private var showNoteEditor = false
    @State private var editingNote: NoteRecord?

    init(deckId: Int64, onDismiss: @escaping () -> Void) {
        self.deckId = deckId
        self.onDismiss = onDismiss
        self._session = State(initialValue: ReviewSession(deckId: deckId))
    }

    var body: some View {
        NavigationStack {
            ZStack {
                // 主要内容
                VStack(spacing: 0) {
                    HStack(spacing: 12) {
                        DeckCountsView(counts: session.remainingCounts)
                        Spacer()
                        Text(\"\\(session.sessionStats.reviewed) reviewed\")
                            .font(.caption)
                            .foregroundStyle(.secondary)
                    }
                    .padding(.horizontal)
                    .padding(.vertical, 8)

                    if session.isFinished {
                        finishedView
                    } else {
                        cardView
                    }
                }
                .navigationBarTitleDisplayMode(.inline)
                .toolbar {
                    ToolbarItem(placement: .topBarLeading) {
                        Button(\"Done\") { onDismiss() }
                    }
                    ToolbarItem(placement: .topBarTrailing) {
                        Button {
                            showCardMenu = true
                        } label: {
                            Image(systemName: \"ellipsis.circle\")
                        }
                    }
                }
                
                // 卡片菜单（覆盖层）
                if showCardMenu && !session.isFinished {
                    ZStack {
                        // 半透明背景
                        Color.black.opacity(0.2)
                            .ignoresSafeArea()
                            .onTapGesture {
                                showCardMenu = false
                            }
                        
                        // 菜单内容
                        VStack {
                            Spacer()
                            
                            CardContextMenuView(session: _session)
                                .transition(.move(edge: .bottom).combined(with: .opacity))
                            
                            Spacer()
                        }
                    }
                    .transition(.opacity)
                }
                
                // 笔记编辑 Sheet
                if showNoteEditor, let note = editingNote {
                    NavigationStack {
                        NoteEditorView(note: note) {
                            showNoteEditor = false
                            // 重新加载当前卡片的内容
                            Task { session.reloadCurrentCard() }
                        }
                    }
                    .transition(.move(edge: .bottom))
                }
            }
            .task {
                session.start()
            }
        }
    }

    @ViewBuilder
    private var cardView: some View {
        VStack(spacing: 0) {
            if session.showAnswer {
                CardWebView(html: session.backHTML)
                    .onLongPressGesture(minimumDuration: 0.5) {
                        showCardMenu = true
                    }
            } else {
                CardWebView(html: session.frontHTML)
                    .onLongPressGesture(minimumDuration: 0.5) {
                        showCardMenu = true
                    }
            }

            Spacer()

            if session.showAnswer {
                answerButtons
            } else {
                Button {
                    session.revealAnswer()
                } label: {
                    Text(\"Show Answer\")
                        .font(.headline)
                        .frame(maxWidth: .infinity)
                        .padding()
                }
                .buttonStyle(.borderedProminent)
                .padding()
            }
        }
    }

    private var answerButtons: some View {
        HStack(spacing: 8) {
            ratingButton(.again, color: .red)
            ratingButton(.hard, color: .orange)
            ratingButton(.good, color: .green)
            ratingButton(.easy, color: .blue)
        }
        .padding()
    }

    private func ratingButton(_ rating: Rating, color: Color) -> some View {
        Button {
            session.answer(rating: rating)
        } label: {
            VStack(spacing: 4) {
                Text(session.nextIntervals[rating] ?? \"\")
                    .font(.caption2)
                Text(ratingLabel(rating))
                    .font(.subheadline.weight(.medium))
            }
            .frame(maxWidth: .infinity)
            .padding(.vertical, 10)
        }
        .buttonStyle(.bordered)
        .tint(color)
    }

    private func ratingLabel(_ rating: Rating) -> String {
        switch rating {
        case .again: \"Again\"
        case .hard: \"Hard\"
        case .good: \"Good\"
        case .easy: \"Easy\"
        }
    }

    @ViewBuilder
    private var finishedView: some View {
        // 显示复习完成信息
        VStack(spacing: 16) {
            Image(systemName: \"checkmark.circle.fill\")
                .font(.system(size: 48))
                .foregroundStyle(.green)
            
            Text(\"Great job!\")
                .font(.title2.weight(.bold))
            
            Text(\"\\(session.sessionStats.reviewed) cards reviewed\")
                .foregroundStyle(.secondary)
            
            Spacer()
        }
        .padding()
    }
}

// ===== 第4步：在 ReviewSession 中添加新的状态属性 =====

// 在 ReviewSession.swift 的 @Observable class 中添加：

@Observable @MainActor
final class ReviewSession {
    // ... 现有属性 ...
    
    var showCardMenu = false
    var showCardInfo = false
    var showNoteEditor = false
    var editingNote: NoteRecord?
    
    // 统计信息扩展
    var sessionStats = SessionStats(
        suspended: 0,
        buried: 0,
        flagged: 0
    )
}

struct SessionStats {
    var reviewed: Int = 0
    var suspended: Int = 0
    var buried: Int = 0
    var flagged: Int = 0
}
